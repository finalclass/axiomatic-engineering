(version 3.22.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune ocaml base-unix csexp)))

(source
 (fetch
  (url
   https://github.com/ocaml/dune/releases/download/3.22.0/dune-3.22.0.tbz)
  (checksum
   sha256=cb816b2e672ca6c6ea680133f01287bd95a58ca611cb476acff67b8adbacf722)))
